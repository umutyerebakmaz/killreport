model TerritoryChange {
  id                  BigInt   @id @default(autoincrement())
  solar_system_id     Int
  previous_owner_id   Int? // alliance_id before the change
  new_owner_id        Int? // alliance_id after the change
  previous_faction_id Int?
  new_faction_id      Int?
  change_type         String // captured, lost, transferred, faction_change
  detected_at         DateTime @default(now())

  @@index([solar_system_id, detected_at])
  @@index([previous_owner_id])
  @@index([new_owner_id])
  @@map("territory_changes")
}
