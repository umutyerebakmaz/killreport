model Killmail {
  killmail_id     Int            @id
  killmail_hash   String
  killmail_time   DateTime
  solar_system_id Int
  total_value     Float?         // Cached value calculated at insertion time
  destroyed_value Float?         // Cached value calculated at insertion time
  dropped_value   Float?         // Cached value calculated at insertion time
  attacker_count  Int?           // Cached attacker count at insertion time
  // Sovereignty war correlation (set by worker-sovereignty-correlate):
  related_campaign_id Int?       // campaign_id of the active sov campaign this kill belongs to, if any
  is_war_related      Boolean    @default(false)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  attackers       Attacker[]
  items           KillmailItem[]
  victim          Victim?

  @@index([killmail_time])
  @@index([solar_system_id])
  @@index([total_value(sort: Desc)])
  @@index([attacker_count])
  @@index([related_campaign_id])
  @@index([is_war_related])
  @@map("killmails")
}
