model CampaignCombatStats {
  campaign_id     Int      @id
  war_kills       Int      @default(0)
  isk_destroyed   Float    @default(0)
  ships_destroyed Int      @default(0)
  // Attacker-vs-defender split of the totals above. A kill counts as a
  // defender loss when the victim's alliance == the campaign defender_id,
  // otherwise as an attacker/third-party loss.
  defender_isk_lost   Float @default(0)
  attacker_isk_lost   Float @default(0)
  defender_ships_lost Int   @default(0)
  attacker_ships_lost Int   @default(0)
  last_correlated DateTime @updatedAt

  campaign        SovereigntyCampaign @relation(fields: [campaign_id], references: [campaign_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([isk_destroyed])
  @@map("campaign_combat_stats")
}
