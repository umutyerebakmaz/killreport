{
    "angular.enable-strict-mode-prompt": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
    "editor.rulers": [
        140
    ],
    "workbench.colorCustomizations": {
        "editorRuler.foreground": "#585858"
    },
    "eslint.workingDirectories": [
        "src"
    ],
    "editor.linkedEditing": true,
    "html.autoClosingTags": true,
    "javascript.autoClosingTags": true,
    "typescript.autoClosingTags": true,
    "editor.fontFamily": "MesloLGM Nerd Font",
    "markdown.preview.fontFamily": "MesloLGM Nerd Font",
    "terminal.integrated.fontFamily": "MesloLGM Nerd Font",
    "angular-schematics.schematicsDefaultOptions": {
        "angular-*": {
            "style": "scss",
            "skipStyle": true
        },
        "angular-component": {
            "ngOnInit": true
        }
    },
    "findUnusedExports.detectCircularImports": true,
    "html.format.wrapAttributesIndentSize": 180,
    "editor.insertSpaces": true,
    "editor.indentSize": "tabSize",
    "[typescript]": {
        "editor.tabSize": 4
    },
    "prettier.tabWidth": 4,
    "editor.formatOnSave": true
}